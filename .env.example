# Copy this file to .env when the application phase begins.
# Add variable names and safe example values only; never place real secrets here.

APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://telemetry:telemetry_dev_password@localhost:5433/telemetry
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC=devices/+/telemetry
